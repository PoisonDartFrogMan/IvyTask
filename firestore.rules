rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // settings: ドキュメントIDがユーザーIDと一致する場合のみ
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // users: for storing user specific data like secret diary password
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // tasks
    match /tasks/{taskId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;
    }

    // labels
    match /labels/{labelId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;
    }

    // memos
    match /memos/{memoId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;
    }

    // memo_folders
    match /memo_folders/{folderId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;
    }

    // vaults
    match /vaults/{vaultId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;
    }

    // shared_vault_items (for one-time password sharing)
    match /shared_vault_items/{itemId} {
      allow read, write: if request.auth != null;
    }

    // candidates
    match /candidates/{candidateId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;
    }

    // employees (マスターUIDのみアクセス可能)
    match /employees/{employeeId} {
      allow read, write: if request.auth != null && request.auth.uid == "8V7CfCrj4wSD8aZymfrf1WKZaAg1";
    }

    // voice_archives (マスターUIDのみアクセス可能)
    match /voice_archives/{archiveId} {
      allow read, write: if request.auth != null && request.auth.uid == "8V7CfCrj4wSD8aZymfrf1WKZaAg1";
    }

    // recurring_tasks
    match /recurring_tasks/{taskId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;
    }

    // pdfs (isSecret == true のドキュメントはマスターUIDのみアクセス可能)
    match /pdfs/{pdfId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId
        && (resource.data.isSecret != true || request.auth.uid == "8V7CfCrj4wSD8aZymfrf1WKZaAg1");
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;

      match /notes/{noteId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/pdfs/$(pdfId)).data.userId;
        allow create: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/pdfs/$(pdfId)).data.userId;
        allow list: if request.auth != null;
      }
    }
    // user_profiles (招待機能でメール→UID検索に使用)
    match /user_profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // chat_invitations (招待保留データ)
    match /chat_invitations/{invitationId} {
      allow read, write: if request.auth != null;
    }

    // chat_rooms (招待制: membersに含まれるユーザーのみアクセス可能)
    match /chat_rooms/{roomId} {
      allow read, delete: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;
      allow list: if request.auth != null;
      // 既存メンバーは通常更新可、非メンバーは自分のUID追加のみ可（招待処理用）
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
         request.resource.data.members.hasAll(resource.data.members) &&
         request.auth.uid in request.resource.data.members)
      );
    }

    // chat_messages
    match /chat_messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // pp_contacts (アドレス帳)
    match /pp_contacts/{contactId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
